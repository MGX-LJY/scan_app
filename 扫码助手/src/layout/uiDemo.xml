<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xmlns:android="http://schemas.android.com/apk/res/android" xsi:noNamespaceSchemaLocation="layout.xsd"
            android:layout_height="match_parent" android:layout_width="match_parent">
    <LinearLayout android:layout_height="match_parent" android:layout_width="match_parent"
                  android:orientation="vertical" android:padding="20dp">

        <!-- 版本号 -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:tag="version" android:text="版本号: " android:padding="10dp"/>

        <!-- 设备ID -->
        <LinearLayout android:layout_height="wrap_content" android:orientation="horizontal"
                      android:layout_width="match_parent" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="设备ID: "/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="deviceId" android:text="" android:padding="5dp"/>
        </LinearLayout>

        <!-- 服务器IP -->
        <LinearLayout android:layout_height="wrap_content" android:orientation="horizontal"
                      android:layout_width="match_parent" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="服务器IP: "/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="serverIp" android:hint="请输入内网服务器IP"/>
        </LinearLayout>

        <!-- 微信账号 -->
        <LinearLayout android:layout_height="wrap_content" android:orientation="horizontal"
                      android:layout_width="match_parent" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:text="微信账号: "/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="weixinArr" android:hint="多个账号用#分隔(最多2个)"/>
        </LinearLayout>

        <!-- 开关区域 -->
        <Switch android:text="日志窗口：" android:tag="logFW"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <Switch android:text="控制开关：" android:tag="kongZhi"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <Switch android:text="无障碍服务：" android:tag="wuzhangai"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <!-- 运行模式 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="运行模式: " android:padding="10dp"/>
        <RadioGroup android:layout_height="wrap_content" android:orientation="vertical"
                    android:layout_width="match_parent">
            <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content"
                         android:tag="isWuZhangAi" android:text="无障碍模式"/>
            <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content"
                         android:tag="isDaiLi" android:text="代理模式"/>
        </RadioGroup>

        <!-- 按钮区域 -->
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent"
                      android:layout_height="wrap_content" android:padding="10dp">
            <Button android:text="保存参数" android:layout_weight="1" android:tag="saveAllBtn"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
            <Button android:text="退出" android:layout_weight="1" android:tag="exitBtn"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
